# Dependencies — reinstalled via `npm ci` inside the container
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Build outputs & caches — rebuilt inside the container
.next/
out/
build/
coverage/
*.tsbuildinfo
tsconfig.tsbuildinfo

# Environment & secrets — inject via runtime env vars, never bake into images
.env
.env.*
*.pem

# VCS & CI metadata
.git/
.github/
.gitignore
.gitattributes

# Local development tools (not needed at runtime)
.claude/
.playwright-mcp/
.superpowers/
.cursor/
.mcp.json
.vscode/
.idea/
*.swp
*.swo
*~

# Internal documentation & planning (not needed at runtime)
_planning/
_docs/
_reviews/
_reference/
docs/
CLAUDE.md
README.md
*.md
!public/**/*.md

# OS artifacts
.DS_Store
Thumbs.db

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Deploy platform artifacts
.vercel/
.turbo/
.netlify/

# Supabase local (CLI state)
supabase/.branches/
supabase/.temp/

# Dockerfile itself isn't needed inside the image
Dockerfile
.dockerignore
